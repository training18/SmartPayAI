// ─────────────────────────────────────────────────────────────────────────────
// SmartPayAI — Prisma Schema
// Complete database model for AI-powered payment orchestration.
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  PERSONAL
  MERCHANT
}

enum VirtualCardStatus {
  ACTIVE
  FROZEN
  EXPIRED
}

enum TransactionStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
  FAILED
}

enum RewardType {
  CASHBACK
  POINTS
  MILES
  DISCOUNT
  INSTALLMENT
  NONE
}

enum CardType {
  CREDIT
  DEBIT
  PREPAID
}

// ── Users ────────────────────────────────────────────────────────────────────

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String
  fullName      String
  role          UserRole @default(PERSONAL)
  isOnboarded   Boolean  @default(false)
  refreshToken  String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  virtualCard   VirtualCard?
  savedCards    SavedCard[]
  transactions  Transaction[]

  @@map("users")
}

// ── Virtual Cards (Demo) ─────────────────────────────────────────────────────

model VirtualCard {
  id            String            @id @default(uuid())
  userId        String            @unique
  cardNumber    String            @unique
  expiryMonth   Int
  expiryYear    Int
  cvv           String
  cardHolder    String
  balance       Decimal           @default(10000.00) @db.Decimal(12, 2)
  provider      String            @default("SmartPay")
  status        VirtualCardStatus @default(ACTIVE)

  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("virtual_cards")
}

// ── Saved Cards (User's real cards — tokenized, no sensitive data) ───────────

model SavedCard {
  id            String     @id @default(uuid())
  userId        String
  bankName      String
  cardType      CardType   @default(CREDIT)
  last4         String     @db.VarChar(4)
  cardAlias     String?
  holderName    String?
  monthlyLimit  Decimal?   @db.Decimal(12, 2)
  rewardType    RewardType @default(NONE)

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  recommendations Recommendation[]

  @@map("saved_cards")
}

// ── Campaigns ────────────────────────────────────────────────────────────────

model Campaign {
  id              String     @id @default(uuid())
  title           String
  description     String
  bankName        String
  cardType        CardType?
  rewardType      RewardType
  category        String
  rewardRate      Decimal    @db.Decimal(5, 2)
  minAmount       Decimal?   @db.Decimal(12, 2)
  maxReward       Decimal?   @db.Decimal(12, 2)
  installmentCount Int?
  isActive        Boolean    @default(true)

  startsAt        DateTime   @default(now())
  endsAt          DateTime?

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([category, bankName])
  @@index([isActive])
  @@map("campaigns")
}

// ── Merchants (AI-analyzed cache) ────────────────────────────────────────────

model Merchant {
  id            String   @id @default(uuid())
  name          String   @unique
  normalizedName String  @unique
  category      String
  mcc           String?
  spendingType  String?
  aiMetadata    Json?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  transactions  Transaction[]

  @@index([normalizedName])
  @@index([category])
  @@map("merchants")
}

// ── Transactions ─────────────────────────────────────────────────────────────

model Transaction {
  id              String            @id @default(uuid())
  userId          String
  merchantId      String?
  merchantName    String
  amount          Decimal           @db.Decimal(12, 2)
  currency        String            @default("TRY")
  description     String?
  status          TransactionStatus @default(PENDING)
  mcc             String?

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  merchant        Merchant?         @relation(fields: [merchantId], references: [id])
  recommendation  Recommendation?

  @@index([userId, status])
  @@index([createdAt])
  @@map("transactions")
}

// ── Recommendations (AI output) ──────────────────────────────────────────────

model Recommendation {
  id                String   @id @default(uuid())
  transactionId     String   @unique
  recommendedCardId String?
  merchantCategory  String
  recommendedBank   String
  reason            String   @db.Text
  estimatedBenefit  String
  confidence        Decimal  @db.Decimal(3, 2)
  aiRawResponse     Json?

  createdAt         DateTime @default(now())

  transaction       Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  recommendedCard   SavedCard?  @relation(fields: [recommendedCardId], references: [id])

  @@map("recommendations")
}
