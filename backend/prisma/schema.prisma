// ─────────────────────────────────────────────────────────────────────────────
// SmartPayAI — Prisma Schema
// Complete database model for AI-powered payment orchestration.
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  PERSONAL
  MERCHANT
}

enum VirtualCardStatus {
  ACTIVE
  FROZEN
  EXPIRED
}

enum TransactionStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
  FAILED
}

enum RewardType {
  CASHBACK
  POINTS
  MILES
  DISCOUNT
  INSTALLMENT
  NONE
}

enum CardType {
  CREDIT
  DEBIT
  PREPAID
}

// ── Users ────────────────────────────────────────────────────────────────────

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String
  fullName      String
  role          UserRole @default(PERSONAL)
  isOnboarded   Boolean  @default(false)
  refreshToken  String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  virtualCard   VirtualCard?
  savedCards    SavedCard[]
  transactions  Transaction[]
  shipments     Shipment[]
  shippingAnalytics ShippingAnalytics?

  @@map("users")
}

// ── Virtual Cards (Demo) ─────────────────────────────────────────────────────

model VirtualCard {
  id            String            @id @default(uuid())
  userId        String            @unique
  cardNumber    String            @unique
  expiryMonth   Int
  expiryYear    Int
  cvv           String
  cardHolder    String
  balance       Decimal           @default(10000.00) @db.Decimal(12, 2)
  provider      String            @default("SmartPay")
  status        VirtualCardStatus @default(ACTIVE)

  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("virtual_cards")
}

// ── Saved Cards (User's real cards — tokenized, no sensitive data) ───────────

model SavedCard {
  id            String     @id @default(uuid())
  userId        String
  bankName      String
  cardType      CardType   @default(CREDIT)
  first4        String     @db.VarChar(4)
  cardAlias     String?
  holderName    String?
  monthlyLimit  Decimal?   @db.Decimal(12, 2)
  rewardType    RewardType @default(NONE)

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  recommendations Recommendation[]

  @@map("saved_cards")
}

// ── Campaign Source ──────────────────────────────────────────────────────────

enum CampaignSource {
  MANUAL
  SEED
  SCRAPED
  API
}

// ── Campaigns ────────────────────────────────────────────────────────────────

model Campaign {
  id              String     @id @default(uuid())
  title           String
  description     String
  bankName        String
  cardType        CardType?
  rewardType      RewardType
  category        String
  rewardRate      Decimal    @db.Decimal(5, 2)
  minAmount       Decimal?   @db.Decimal(12, 2)
  maxReward       Decimal?   @db.Decimal(12, 2)
  installmentCount Int?
  isActive        Boolean    @default(true)

  // ── Source tracking (real-time campaign intelligence) ──
  source          CampaignSource @default(MANUAL)
  sourceId        String?        @unique       // deduplication key
  rawText         String?        @db.Text      // original marketing text
  network         String?                      // Visa, Mastercard, Troy, etc.
  channels        String[]       @default([])  // ["online", "offline"]
  rewardCurrency  String?                      // MaxiPuan, Worldpuan, chip-para, mil, TL
  parsedByAi      Boolean        @default(false)
  fetchedAt       DateTime?

  startsAt        DateTime   @default(now())
  endsAt          DateTime?

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@unique([bankName, title, category])
  @@index([category, bankName])
  @@index([isActive])
  @@map("campaigns")
}

// ── MCC Mappings (Merchant Category Code → spending category) ────────────────

model MccMapping {
  mcc         String   @id @db.VarChar(4)
  category    String
  description String?
  keywords    String[] @default([])

  @@index([category])
  @@map("mcc_mappings")
}

// ── Merchants (AI-analyzed cache) ────────────────────────────────────────────

model Merchant {
  id            String   @id @default(uuid())
  name          String   @unique
  normalizedName String  @unique
  category      String
  mcc           String?
  spendingType  String?
  aiMetadata    Json?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  transactions  Transaction[]

  @@index([normalizedName])
  @@index([category])
  @@map("merchants")
}

// ── Transactions ─────────────────────────────────────────────────────────────

model Transaction {
  id              String            @id @default(uuid())
  userId          String
  merchantId      String?
  merchantName    String
  amount          Decimal           @db.Decimal(12, 2)
  currency        String            @default("TRY")
  description     String?
  status          TransactionStatus @default(PENDING)
  mcc             String?

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  merchant        Merchant?         @relation(fields: [merchantId], references: [id])
  recommendation  Recommendation?

  @@index([userId, status])
  @@index([createdAt])
  @@map("transactions")
}

// ── Recommendations (AI output) ──────────────────────────────────────────────

model Recommendation {
  id                 String   @id @default(uuid())
  transactionId      String   @unique
  recommendedCardId  String?
  merchantCategory   String
  recommendedBank    String
  recommendedNetwork String?
  reason             String   @db.Text
  estimatedBenefit   String
  confidence         Decimal  @db.Decimal(3, 2)

  // ── Structured routing trace (populated by RoutingSimulationService) ────
  savingsBreakdown   Json?
  rejectedCards      Json?
  campaignMatches    Json?
  aiRawResponse      Json?

  // ── TRY Savings Values ──
  cashbackEarned    Decimal @default(0.00) @db.Decimal(12, 2)
  discountAmount    Decimal @default(0.00) @db.Decimal(12, 2)
  pointsValue       Decimal @default(0.00) @db.Decimal(12, 2)
  installmentValue  Decimal @default(0.00) @db.Decimal(12, 2)
  aiRoutingGain     Decimal @default(0.00) @db.Decimal(12, 2)
  totalSavedAmount  Decimal @default(0.00) @db.Decimal(12, 2)

  createdAt          DateTime @default(now())

  transaction        Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  recommendedCard    SavedCard?  @relation(fields: [recommendedCardId], references: [id])

  @@map("recommendations")
}

// ── Cargo Providers ──────────────────────────────────────────────────────────

model CargoProvider {
  id                  String   @id @default(uuid())
  name                String
  code                String   @unique
  baseRate            Decimal  @db.Decimal(12, 2)
  perKgRate           Decimal  @db.Decimal(12, 2)
  perDesiRate         Decimal  @db.Decimal(12, 2)
  reliabilityScore    Decimal  @db.Decimal(5, 2) // e.g. 91.00
  deliverySuccessRate Decimal  @db.Decimal(5, 2) // e.g. 98.50
  avgDeliveryDays     Decimal  @db.Decimal(3, 1) // e.g. 1.5
  isActive            Boolean  @default(true)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  quotes              ShipmentQuote[]
  shipments           Shipment[]

  @@map("cargo_providers")
}

// ── Shipments ────────────────────────────────────────────────────────────────

model Shipment {
  id                    String   @id @default(uuid())
  merchantId            String
  senderName            String
  senderAddress         String
  senderCity            String
  receiverName          String
  receiverAddress       String
  receiverCity          String
  width                 Decimal  @db.Decimal(8, 2)
  height                Decimal  @db.Decimal(8, 2)
  length                Decimal  @db.Decimal(8, 2)
  desi                  Decimal  @db.Decimal(8, 2)
  weight                Decimal  @db.Decimal(8, 2)
  status                String   @default("PENDING") // PENDING, SHIPPED, DELIVERED, CANCELLED
  selectedProviderId    String?
  finalPrice            Decimal? @db.Decimal(12, 2)
  estimatedDeliveryDays Int?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  merchant              User            @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  selectedProvider      CargoProvider?  @relation(fields: [selectedProviderId], references: [id])
  quotes                ShipmentQuote[]
  tracking              ShipmentTracking[]

  @@map("shipments")
}

// ── Shipment Quotes (Normalized pricing) ────────────────────────────────────

model ShipmentQuote {
  id                    String   @id @default(uuid())
  shipmentId            String
  providerId            String
  price                 Decimal  @db.Decimal(12, 2)
  estimatedDeliveryDays Int
  aiScore               Decimal  @db.Decimal(5, 2) // 0-100
  rank                  Int
  isRecommended         Boolean  @default(false)
  createdAt             DateTime @default(now())

  shipment              Shipment      @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  provider              CargoProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([shipmentId, providerId])
  @@map("shipment_quotes")
}

// ── Shipment Tracking ────────────────────────────────────────────────────────

model ShipmentTracking {
  id          String   @id @default(uuid())
  shipmentId  String
  status      String
  location    String
  description String
  createdAt   DateTime @default(now())

  shipment    Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@map("shipment_tracking")
}

// ── Shipping Analytics ───────────────────────────────────────────────────────

model ShippingAnalytics {
  id             String   @id @default(uuid())
  merchantId     String   @unique
  totalShipments Int      @default(0)
  totalSpent     Decimal  @default(0.00) @db.Decimal(12, 2)
  totalSaved     Decimal  @default(0.00) @db.Decimal(12, 2)
  avgDeliveryTime Decimal  @default(0.00) @db.Decimal(5, 2)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  merchant       User     @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@map("shipping_analytics")
}

