# ── Database ──────────────────────────────────────
DATABASE_URL=postgresql://smartpay:smartpay@localhost:5432/smartpay

# ── Redis ─────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── JWT ───────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-secret-key-at-least-32-chars
JWT_REFRESH_SECRET=change-me-to-another-random-secret-key
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ── AI (Google Gemini) ────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here

# ── Server ────────────────────────────────────────
PORT=3000
NODE_ENV=development
